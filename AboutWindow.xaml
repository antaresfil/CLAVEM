<Window x:Class="CLAVEM.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About CLAVEM"
        Height="640" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F0E8"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextFormattingMode="Display"
        RenderOptions.ClearTypeHint="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════ HEADER ══════════════ -->
        <Border Grid.Row="0" Background="#1A1208" Padding="30,24">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="14" ShadowDepth="2" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel HorizontalAlignment="Center">
                <Border CornerRadius="16" Width="120" Height="120"
                        HorizontalAlignment="Center" Margin="0,0,0,14" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect Color="#C9A84C" BlurRadius="16" ShadowDepth="0" Opacity="0.4"/>
                    </Border.Effect>
                    <Image Source="Resources/clavem_logo.png" Width="120" Height="120"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="CLAVEM"
                           FontFamily="Palatino Linotype"
                           FontSize="32" FontWeight="Bold"
                           Foreground="#E8C040"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="File Encryption by Massimo Parisi (Antaresfil)"
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#A08040" Margin="0,6,0,0"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="xilomen@gmail.com"
                           FontFamily="Segoe UI" FontSize="12"
                           Foreground="#7A6A3E" Margin="0,4,0,0"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="VersionText" Text="Version"
                           FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                           Foreground="#C9A84C" Margin="0,8,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ══════════════ CONTENT ══════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,18">
            <StackPanel>

                <!-- Developer Info -->
                <Border Background="White" Padding="20" CornerRadius="10"
                        BorderBrush="#E8DFC8" BorderThickness="1" Margin="0,0,0,14">
                    <Border.Effect>
                        <DropShadowEffect Color="#1A1208" BlurRadius="6" ShadowDepth="1" Opacity="0.06"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="👨‍💻  Developer Information"
                                   FontFamily="Palatino Linotype"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#8B6914" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Developer:"
                                       FontWeight="Bold" Foreground="#A08040" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="Antaresfil (Massimo Parisi)"
                                       Foreground="#6B5A2E" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Email:"
                                       FontWeight="Bold" Foreground="#A08040" FontSize="13"/>
                            <TextBlock Grid.Column="1" FontSize="13">
                                <Hyperlink NavigateUri="mailto:xilomen@gmail.com" RequestNavigate="Hyperlink_RequestNavigate"
                                           Foreground="#C9A84C">
                                    <Run Text="xilomen@gmail.com"/>
                                </Hyperlink>
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Support:"
                                       FontWeight="Bold" Foreground="#A08040" FontSize="13"/>
                            <TextBlock Grid.Column="1" FontSize="13">
                                <Hyperlink NavigateUri="mailto:clavemhelp@noxfarm.com" RequestNavigate="Hyperlink_RequestNavigate"
                                           Foreground="#C9A84C">
                                    <Run Text="clavemhelp@noxfarm.com"/>
                                </Hyperlink>
                            </TextBlock>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Copyright:"
                                       FontWeight="Bold" Foreground="#A08040" FontSize="13"/>
                            <TextBlock Grid.Column="1"
                                       Text="© 2026 Massimo Parisi (Antaresfil). All rights reserved."
                                       Foreground="#6B5A2E" FontSize="13"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- License -->
                <Border Background="White" Padding="20" CornerRadius="10"
                        BorderBrush="#E8DFC8" BorderThickness="1" Margin="0,0,0,14">
                    <Border.Effect>
                        <DropShadowEffect Color="#1A1208" BlurRadius="6" ShadowDepth="1" Opacity="0.06"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📜  License"
                                   FontFamily="Palatino Linotype"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#8B6914" Margin="0,0,0,14"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,10" FontSize="13">
                            <Run FontWeight="Bold" Foreground="#6B5A2E">FREE FOR PERSONAL USE</Run>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,14" LineHeight="20"
                                   FontSize="13" Foreground="#6B5A2E">
                            This software is provided free of charge for personal, non-commercial use only.
                        </TextBlock>
                        <TextBlock Text="✅  You ARE allowed to:" FontWeight="Bold"
                                   Foreground="#5A7A3A" Margin="0,0,0,6" FontSize="13"/>
                        <TextBlock TextWrapping="Wrap" Margin="14,0,0,4" LineHeight="18"
                                   FontSize="12" Foreground="#6B5A2E">• Use this software for personal purposes</TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="14,0,0,4" LineHeight="18"
                                   FontSize="12" Foreground="#6B5A2E">• Install on multiple personal devices</TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="14,0,0,14" LineHeight="18"
                                   FontSize="12" Foreground="#6B5A2E">• Share the original unmodified installer with others</TextBlock>
                        <TextBlock Text="❌  You are NOT allowed to:" FontWeight="Bold"
                                   Foreground="#8B3030" Margin="0,0,0,6" FontSize="13"/>
                        <TextBlock TextWrapping="Wrap" Margin="14,0,0,4" LineHeight="18"
                                   FontSize="12" Foreground="#6B5A2E">• Use this software for commercial purposes</TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="14,0,0,4" LineHeight="18"
                                   FontSize="12" Foreground="#6B5A2E">• Modify, reverse engineer, or decompile the software</TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="14,0,0,4" LineHeight="18"
                                   FontSize="12" Foreground="#6B5A2E">• Redistribute modified versions</TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="14,0,0,14" LineHeight="18"
                                   FontSize="12" Foreground="#6B5A2E">• Sell or charge for this software</TextBlock>

                        <Border Background="#FDF5E0" BorderBrush="#E0C870" BorderThickness="1"
                                Padding="14" CornerRadius="6" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="💼  Commercial Use" FontWeight="Bold"
                                           Foreground="#8B6914" Margin="0,0,0,5" FontSize="13"/>
                                <TextBlock TextWrapping="Wrap" Foreground="#6B5A2E" LineHeight="18" FontSize="12">
                                    For commercial use, business environments or enterprise deployment,
                                    please contact the developer at xilomen@gmail.com for licensing options.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Disclaimer -->
                <Border Background="#FDF5E0" BorderBrush="#D4A830" BorderThickness="2"
                        Padding="20" CornerRadius="10" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="⚠️  CRITICAL WARNINGS &amp; DISCLAIMER"
                                   FontFamily="Palatino Linotype"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#8B3030" Margin="0,0,0,14"/>

                        <TextBlock TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,10" FontSize="13">
                            <Run FontWeight="Bold" Foreground="#8B3030">🔐  PASSWORD AND KEYFILE LOSS:</Run>
                            <LineBreak/>
                            <Run Foreground="#6B5A2E">If you lose your password or keyfile, your encrypted data is </Run>
                            <Run FontWeight="Bold" Foreground="#8B3030">PERMANENTLY UNRECOVERABLE</Run>
                            <Run Foreground="#6B5A2E">. There is NO backdoor, NO recovery method. </Run>
                            <Run FontWeight="Bold" Foreground="#6B5A2E">Store your credentials safely!</Run>
                        </TextBlock>

                        <TextBlock TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,10" FontSize="13">
                            <Run FontWeight="Bold" Foreground="#8B3030">💾  DATA BACKUP REQUIRED:</Run>
                            <LineBreak/>
                            <Run Foreground="#6B5A2E">ALWAYS maintain backups before encrypting. The developer is </Run>
                            <Run FontWeight="Bold" Foreground="#8B3030">NOT responsible for any data loss or corruption</Run>
                            <Run Foreground="#6B5A2E"> during operations.</Run>
                        </TextBlock>

                        <TextBlock TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,10" FontSize="13">
                            <Run FontWeight="Bold" Foreground="#8B3030">🗑️  SECURE DELETE IS PERMANENT:</Run>
                            <LineBreak/>
                            <Run Foreground="#6B5A2E">When "Secure Delete" is enabled, the original file is overwritten and deleted. This action is </Run>
                            <Run FontWeight="Bold" Foreground="#8B3030">irreversible</Run>
                            <Run Foreground="#6B5A2E">. Cannot be fully guaranteed on SSD/NVMe drives.</Run>
                        </TextBlock>

                        <Border Background="#FFEBEE" BorderBrush="#D4A0A0" BorderThickness="1"
                                Padding="12" CornerRadius="6" Margin="0,8,0,8">
                            <StackPanel>
                                <TextBlock Text="📜  LEGAL DISCLAIMER" FontWeight="Bold"
                                           Foreground="#8B3030" Margin="0,0,0,5" FontSize="13"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="16" Foreground="#6B3030">
                                    This software is provided "AS IS" without warranty of any kind. In no event shall
                                    the developer (Massimo Parisi) be liable for any claim, damages or other liability
                                    arising from the use of this software. Use at your own risk.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock TextWrapping="Wrap" FontWeight="Bold" FontSize="12"
                                   Foreground="#8B3030" HorizontalAlignment="Center" Margin="0,6,0,0">
                            BY USING THIS SOFTWARE, YOU ACCEPT ALL RISKS AND DISCLAIMERS ABOVE.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Best Practices -->
                <Border Background="White" Padding="20" CornerRadius="10"
                        BorderBrush="#E8DFC8" BorderThickness="1" Margin="0,0,0,14">
                    <Border.Effect>
                        <DropShadowEffect Color="#1A1208" BlurRadius="6" ShadowDepth="1" Opacity="0.06"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="✅  BEST PRACTICES"
                                   FontFamily="Palatino Linotype"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#5A7A3A" Margin="0,0,0,14"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,7" FontSize="13" Foreground="#6B5A2E">
                            <Run FontWeight="Bold">1. Test First:</Run>
                            <Run> Always test with non-critical files before encrypting important data.</Run>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,7" FontSize="13" Foreground="#6B5A2E">
                            <Run FontWeight="Bold">2. Backup Everything:</Run>
                            <Run> Keep multiple backups in different locations before encrypting.</Run>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,7" FontSize="13" Foreground="#6B5A2E">
                            <Run FontWeight="Bold">3. Store Credentials Safely:</Run>
                            <Run> Use a password manager. Keep keyfiles in multiple secure locations.</Run>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,7" FontSize="13" Foreground="#6B5A2E">
                            <Run FontWeight="Bold">4. Verify Decryption:</Run>
                            <Run> Always test that encrypted files can be decrypted BEFORE deleting originals.</Run>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#6B5A2E">
                            <Run FontWeight="Bold">5. Secure Delete Carefully:</Run>
                            <Run> Only enable when you are absolutely certain you have a working encrypted copy.</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Encryption Details -->
                <Border Background="#FDF5E0" BorderBrush="#E0C870" BorderThickness="1"
                        Padding="16" CornerRadius="10" Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Text="🔐  Encryption Details"
                                   FontFamily="Palatino Linotype"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="#8B6914" Margin="0,0,0,10"/>
                        <TextBlock FontSize="12" Foreground="#6B5A2E" LineHeight="20">
                            • Algorithm: AES-256-GCM&#10;• Key Derivation: Argon2id (OWASP recommended)&#10;• Authentication: 128-bit GCM tag&#10;• Secure Delete: DoD 5220.22-M (3-pass overwrite)
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════ FOOTER ══════════════ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E8DFC8" BorderThickness="0,1,0,0" Padding="20,14">
            <Grid>
                <TextBlock Text="Made with ❤️ for secure file protection"
                           FontSize="12" Foreground="#A08040" VerticalAlignment="Center"/>
                <Button Content="Close" Width="110" Height="34" HorizontalAlignment="Right"
                        Click="CloseButton_Click"
                        FontFamily="Palatino Linotype" FontSize="13" FontWeight="Bold"
                        Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#D4A830" Offset="0"/>
                            <GradientStop Color="#A07010" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FFD966" Offset="0"/>
                                                <GradientStop Color="#C88A10" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#FFD040" BlurRadius="14" ShadowDepth="0" Opacity="0.7"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
